{
  "name": "nodeterm",
  "version": "1.7.2",
  "author": {
    "name": "kalidus",
    "email": "kalidus@users.noreply.github.com"
  },
  "main": "main.js",
  "desktopName": "nodeterm.desktop",
  "scripts": {
    "start": "electron .",
    "start:cold": "node -e \"try{require('fs').rmSync('.cold-cache',{recursive:true,force:true})}catch(e){}\" && electron . --user-data-dir=.cold-cache",
    "download-fonts": "node scripts/download-fonts.js",
    "build": "npm run download-fonts && webpack --mode production",
    "postinstall": "node scripts/ensure-electron-binary.js && node scripts/rebuild-browser-import-native.js",
    "predev": "node scripts/ensure-electron-binary.js",
    "rebuild:native": "node scripts/rebuild-browser-import-native.js --force",
    "dev": "cross-env NODE_OPTIONS=--no-deprecation concurrently --kill-others \"webpack --watch --mode development\" \"wait-on dist/index.html -t 180000 && cross-env NODE_OPTIONS=--no-deprecation electron .\"",
    "rm-cpu-features": "node -e \"const fs=require('fs'),path=require('path'),r=process.cwd();[path.join(r,'node_modules','cpu-features'),path.join(r,'node_modules','ssh2','node_modules','cpu-features')].forEach(p=>{try{fs.rmSync(p,{recursive:true,force:true})}catch(e){}})\"",
    "pack": "npm run build && npm run rm-cpu-features && electron-builder --dir",
    "verify-packaging": "node scripts/verify-electron-packaging.js",
    "dist": "npm run verify-packaging && npm run build && npm prune --no-audit --no-fund && npm run rm-cpu-features && electron-builder",
    "dist:linux": "npm run build && npm run rm-cpu-features && electron-builder --linux",
    "version:patch": "npm version patch --no-git-tag-version",
    "version:minor": "npm version minor --no-git-tag-version",
    "version:major": "npm version major --no-git-tag-version",
    "version:build": "npm run build && npm run pack",
    "release": "node scripts/release.js",
    "release:patch": "node scripts/release.js --yes --prepare --release-type patch --update-changelog --commit-prep --cloud",
    "release:minor": "node scripts/release.js --yes --prepare --release-type minor --update-changelog --commit-prep --cloud",
    "release:local": "node scripts/release.js --prepare --publish",
    "fix-release-notes": "node scripts/release.js --fix-notes --yes"
  },
  "build": {
    "appId": "com.electron.nodeterm",
    "productName": "NodeTerm",
    "copyright": "Copyright © 2024",
    "compression": "normal",
    "files": [
      "dist/",
      "binaries/**",
      "main.js",
      "config/librechat.full.yaml",
      "preload.js",
      "system-stats-worker.js",
      "package.json",
      "src/main/**",
      "src/shared/**",
      "src/services/**",
      "src/utils/**",
      "src/components/bastion-ssh.js",
      "node_modules/**/*",
      "!**/*.{md,markdown,ts,map,test,spec}",
      "!**/test/**",
      "!**/tests/**",
      "!**/__tests__/**",
      "!**/docs/**",
      "!**/doc/**",
      "!**/examples/**",
      "!**/example/**",
      "!**/.github/**",
      "!**/.git/**",
      "!**/LICENSE*",
      "!**/CHANGELOG*",
      "!**/README*",
      "!**/HISTORY*",
      "!**/CONTRIBUTING*",
      "!**/AUTHORS*",
      "!**/NOTICE*",
      "!**/*.d.ts",
      "!**/coverage/**",
      "!**/.nyc_output/**",
      "!**/.eslintrc*",
      "!**/.prettierrc*",
      "!**/tsconfig.json",
      "!**/jest.config.*",
      "!**/.travis.yml",
      "!**/.circleci/**",
      "!node_modules/electron/**",
      "!node_modules/electron-builder/**",
      "!node_modules/app-builder-bin/**",
      "!node_modules/@electron/**",
      "!node_modules/@types/**",
      "!node_modules/@babel/**",
      "!node_modules/webpack/**",
      "!node_modules/webpack-cli/**",
      "!node_modules/babel-loader/**",
      "!node_modules/copy-webpack-plugin/**",
      "!node_modules/html-webpack-plugin/**",
      "!node_modules/css-loader/**",
      "!node_modules/style-loader/**",
      "!node_modules/concurrently/**",
      "!node_modules/cross-env/**",
      "!node_modules/wait-on/**",
      "!node_modules/electron-reloader/**",
      "!node_modules/baseline-browser-mapping/**",
      "!node_modules/buffer/**",
      "!node_modules/os-browserify/**",
      "!node_modules/path-browserify/**",
      "!node_modules/process/**",
      "!node_modules/querystring-es3/**",
      "!node_modules/stream-browserify/**",
      "!node_modules/url/**",
      "!node_modules/util/**",
      "!node_modules/crypto-browserify/**",
      "!node_modules/pdf-parse/**",
      "!node_modules/react/**",
      "!node_modules/react-dom/**",
      "!node_modules/primereact/**",
      "!node_modules/react-icons/**",
      "!node_modules/@fortawesome/**",
      "!node_modules/@tiptap/**",
      "!node_modules/rxjs/**",
      "!node_modules/highlight.js/**",
      "!node_modules/primeflex/**",
      "!node_modules/primeicons/**",
      "!dist/linux-unpacked/**",
      "!dist/win-unpacked/**",
      "!dist/mac/**",
      "!dist/mac-arm64/**",
      "!dist/*.AppImage",
      "!dist/*.exe",
      "!dist/*.dmg",
      "!dist/*.yml",
      "!dist/*.blockmap",
      "!node_modules/node-pty/src/**",
      "!node_modules/node-pty/deps/**",
      "!node_modules/node-pty/**/*.test.js",
      "!node_modules/node-pty/build/deps/**",
      "!node_modules/node-pty/build/**/obj/**",
      "!node_modules/node-pty/**/*.{iobj,ipdb,pdb,exp,lib,ilk,tlog}",
      "!node_modules/better-sqlite3/deps/**",
      "!node_modules/better-sqlite3/src/**"
    ],
    "asarUnpack": [
      "binaries/**",
      "node_modules/ssh2-promise/**",
      "node_modules/ssh2/**"
    ],
    "win": {
      "target": [
        "nsis",
        "portable"
      ],
      "icon": "src/assets/app-icon.png",
      "verifyUpdateCodeSignature": false,
      "requestedExecutionLevel": "asInvoker",
      "files": [
        "!resources${/*}",
        "!http*/**",
        "!https*/**",
        "!docs${/*}",
        "!scripts${/*}",
        "!testing${/*}",
        "!.agents${/*}",
        "!.rules${/*}",
        "!src/assets${/*}",
        "!src/components${/*}",
        "src/components/bastion-ssh.js",
        "!src/hooks${/*}",
        "!src/i18n${/*}",
        "!src/styles${/*}",
        "!src/themes${/*}",
        "!src/stores${/*}",
        "!src/config${/*}",
        "!src/mcp-servers${/*}",
        "!node_modules/node-pty/prebuilds/win32-arm64/**",
        "!node_modules/node-pty/prebuilds/darwin-*/**",
        "!node_modules/node-pty/prebuilds/linux-*/**",
        "!node_modules/node-pty/third_party/**/win10-arm64/**"
      ]
    },
    "electronLanguages": [
      "en",
      "es"
    ],
    "nsis": {
      "artifactName": "${productName}-Setup-${version}.${ext}",
      "oneClick": true,
      "perMachine": false,
      "allowToChangeInstallationDirectory": false,
      "createDesktopShortcut": true,
      "createStartMenuShortcut": true,
      "shortcutName": "NodeTerm",
      "deleteAppDataOnUninstall": false,
      "differentialPackage": false,
      "warningsAsErrors": false
    },
    "linux": {
      "target": [
        "AppImage",
        "pacman",
        "deb",
        "rpm",
        "tar.xz"
      ],
      "category": "Utility",
      "maintainer": "kalidus <kalidus@users.noreply.github.com>",
      "icon": "src/assets/app-icon.png",
      "files": [
        "!resources${/*}",
        "!http*/**",
        "!https*/**",
        "!docs${/*}",
        "!scripts${/*}",
        "!testing${/*}",
        "!.agents${/*}",
        "!.rules${/*}",
        "!src/assets${/*}",
        "!src/components${/*}",
        "src/components/bastion-ssh.js",
        "!src/hooks${/*}",
        "!src/i18n${/*}",
        "!src/styles${/*}",
        "!src/themes${/*}",
        "!src/stores${/*}",
        "!src/config${/*}",
        "!src/mcp-servers${/*}",
        "!node_modules/node-pty/prebuilds/win32-*/**",
        "!node_modules/node-pty/prebuilds/darwin-*/**",
        "!node_modules/node-pty/third_party/**"
      ]
    },
    "publish": {
      "provider": "github",
      "owner": "kalidus",
      "repo": "NodeTerm",
      "releaseType": "release"
    },
    "mac": {
      "target": [
        {
          "target": "dmg",
          "arch": [
            "x64",
            "arm64"
          ]
        },
        {
          "target": "dir",
          "arch": [
            "x64",
            "arm64"
          ]
        }
      ],
      "icon": "src/assets/app-icon.png",
      "category": "public.app-category.utilities",
      "files": [
        "!resources${/*}",
        "!http*/**",
        "!https*/**",
        "!docs${/*}",
        "!scripts${/*}",
        "!testing${/*}",
        "!.agents${/*}",
        "!.rules${/*}",
        "!src/assets${/*}",
        "!src/components${/*}",
        "src/components/bastion-ssh.js",
        "!src/hooks${/*}",
        "!src/i18n${/*}",
        "!src/styles${/*}",
        "!src/themes${/*}",
        "!src/stores${/*}",
        "!src/config${/*}",
        "!src/mcp-servers${/*}",
        "!node_modules/node-pty/prebuilds/win32-*/**",
        "!node_modules/node-pty/prebuilds/linux-*/**",
        "!node_modules/node-pty/third_party/**"
      ]
    }
  },
  "engines": {
    "node": ">=24 <25"
  },
  "keywords": [],
  "license": "ISC",
  "description": "Aplicación de escritorio multiplataforma con Electron y PrimeReact",
